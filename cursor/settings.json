{
  "cursor.general.emailPrivacyEnabled": true,
  "workbench.colorTheme": "IntelliJ Dark",

  // --- шрифт ---
  "editor.fontFamily": "'PragmataPro Mono Liga', 'PragmataPro Liga', monospace",
  "editor.fontSize": 15,
  "editor.lineHeight": 1.2,
  "editor.fontLigatures": true,

  "peacock.affectActivityBar": false,
  "peacock.affectStatusBar": true,
  "peacock.affectTitleBar": true,
  "peacock.affectAccentBorders": false,
  "window.title": "🟢   ${rootName} ${separator} ${activeEditorShort}",

  // Dracula: подсветка и цвета редактора поверх IntelliJ Dark (UI остаётся IntelliJ)
  "editor.semanticHighlighting.enabled": true,
  "workbench.colorCustomizations": {
    "[IntelliJ Dark]": {
      "editor.foreground": "#F8F8F2",
